@="cmd /c \"cd /d \"%V\" && set NODE_SKIP_PLATFORM_CHECK=1 && node --no-warnings \"C:\\Users\\PC\\AppData\\Roaming\\npm\\node_modules\\@google\\gemini-cli\\bundle\\gemini.js\"\""

