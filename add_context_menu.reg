Windows Registry Editor Version 5.00

[HKEY_CLASSES_ROOT\Directory\Background\shell\GeminiCLI]
@="Open Gemini CLI here"
"Icon"="C:\\Users\\PC\\Desktop\\beep\\web\\html\\favicon.svg"

